# ══════════════════════════════════════════════════════════════════════════════
#  Clarbit DaaS — Frontend environment variables
#  Copy this file to .env.local and fill in your values.
#  .env.local is git-ignored and NEVER committed.
#
#  For Netlify: set these in Site → Environment variables (not in this file).
# ══════════════════════════════════════════════════════════════════════════════

# ── Supabase ──────────────────────────────────────────────────────────────────
# Project → Settings → API in the Supabase dashboard
# https://supabase.com/dashboard/project/<your-ref>/settings/api
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ── Backend API ───────────────────────────────────────────────────────────────
# Local: http://localhost:3001/api/v1
# Production: https://api.clarbit.io/api/v1
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1

# ── Dev bypass ────────────────────────────────────────────────────────────────
# true  → shows "Enter as Demo User" on the login page (local dev / Netlify preview)
# false → requires real authentication (production ONLY)
NEXT_PUBLIC_DEV_BYPASS_AUTH=true

{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": ".",
  "testEnvironment": "node",
  "testRegex": ".e2e-spec.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "moduleNameMapper": {
    "@clarbit/database": "<rootDir>/../../../packages/database/src/index.ts",
    "@clarbit/shared": "<rootDir>/../../../packages/shared/src/index.ts"
  }
}

// ── Shared Secrets (One-Time Secret Sharing) ──────────────────────────────────

model SharedSecret {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String?   @map("tenant_id") @db.Uuid
  creatorId      String?   @map("creator_id") @db.Uuid
  creatorName    String?   @map("creator_name")
  label          String?   @db.Text
  tokenHash      String    @unique @map("token_hash")
  encryptedBlob  String    @map("encrypted_blob") @db.Text
  hasPassphrase  Boolean   @default(false) @map("has_passphrase")
  passphraseHash String?   @map("passphrase_hash")
  ttlSeconds     Int       @default(86400) @map("ttl_seconds")
  expiresAt      DateTime  @map("expires_at")
  viewedAt       DateTime? @map("viewed_at")
  isRevoked      Boolean   @default(false) @map("is_revoked")
  createdAt      DateTime  @default(now()) @map("created_at")

  @@index([tokenHash])
  @@index([tenantId, createdAt(sort: Desc)])
  @@map("shared_secrets")
}

// ── Threat Modelling ──────────────────────────────────────────────────────────

model ThreatModel {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  name          String
  description   String   @default("") @db.Text
  environment   String   @default("HYBRID")
  status        String   @default("DRAFT")
  createdById   String?  @map("created_by_id") @db.Uuid
  createdByName String?  @map("created_by_name")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  components TmComponent[]
  dataFlows  TmDataFlow[]
  threats    TmThreat[]

  @@index([tenantId, createdAt(sort: Desc)])
  @@map("threat_models")
}

model TmComponent {
  id            String   @id @default(uuid()) @db.Uuid
  modelId       String   @map("model_id") @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  name          String
  componentType String   @map("component_type")
  environment   String   @default("CLOUD")
  cloudProvider String?  @map("cloud_provider")
  serviceName   String?  @map("service_name")
  notes         String?  @db.Text
  createdAt     DateTime @default(now()) @map("created_at")

  model       ThreatModel  @relation(fields: [modelId], references: [id], onDelete: Cascade)
  threats     TmThreat[]
  flowsFrom   TmDataFlow[] @relation("FlowSource")
  flowsTo     TmDataFlow[] @relation("FlowTarget")

  @@index([modelId])
  @@map("tm_components")
}

model TmDataFlow {
  id                  String   @id @default(uuid()) @db.Uuid
  modelId             String   @map("model_id") @db.Uuid
  sourceId            String   @map("source_id") @db.Uuid
  targetId            String   @map("target_id") @db.Uuid
  name                String
  protocol            String   @default("HTTPS")
  dataClassification  String   @default("INTERNAL") @map("data_classification")
  isEncrypted         Boolean  @default(true) @map("is_encrypted")
  crossesTrustBoundary Boolean @default(false) @map("crosses_trust_boundary")
  notes               String?  @db.Text
  createdAt           DateTime @default(now()) @map("created_at")

  model   ThreatModel  @relation(fields: [modelId], references: [id], onDelete: Cascade)
  source  TmComponent  @relation("FlowSource", fields: [sourceId], references: [id], onDelete: Cascade)
  target  TmComponent  @relation("FlowTarget", fields: [targetId], references: [id], onDelete: Cascade)
  threats TmThreat[]

  @@index([modelId])
  @@map("tm_data_flows")
}

model TmThreat {
  id               String    @id @default(uuid()) @db.Uuid
  modelId          String    @map("model_id") @db.Uuid
  componentId      String?   @map("component_id") @db.Uuid
  flowId           String?   @map("flow_id") @db.Uuid
  tenantId         String    @map("tenant_id") @db.Uuid
  sourceRef        String?   @map("source_ref")
  title            String
  description      String    @default("") @db.Text
  strideCategory   String    @map("stride_category")
  attackTactic     String    @default("") @map("attack_tactic")
  attackTechnique  String    @default("") @map("attack_technique")
  likelihood       Int       @default(3)
  impact           Int       @default(3)
  riskScore        Int       @default(9) @map("risk_score")
  status           String    @default("OPEN")
  mitigationNotes  String?   @map("mitigation_notes") @db.Text
  isAutoGenerated  Boolean   @default(true) @map("is_auto_generated")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  model     ThreatModel  @relation(fields: [modelId], references: [id], onDelete: Cascade)
  component TmComponent? @relation(fields: [componentId], references: [id], onDelete: SetNull)
  flow      TmDataFlow?  @relation(fields: [flowId], references: [id], onDelete: SetNull)

  @@index([modelId])
  @@index([tenantId])
  @@map("tm_threats")
}

// ── Permission Groups ─────────────────────────────────────────────────────────

model PermissionGroup {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id") @db.Uuid
  name        String
  description String   @default("") @db.Text
  color       String   @default("blue")
  permissions String[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant      Tenant            @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  memberships GroupMembership[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("permission_groups")
}

model GroupMembership {
  id        String   @id @default(uuid()) @db.Uuid
  tenantId  String   @map("tenant_id") @db.Uuid
  groupId   String   @map("group_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  group  PermissionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([tenantId])
  @@index([groupId])
  @@index([userId])
  @@map("group_memberships")
}

// ── SOC Change Management ─────────────────────────────────────────────────────

model SocChange {
  id             String    @id @default(uuid()) @db.Uuid
  tenantId       String    @map("tenant_id") @db.Uuid
  changeRef      String    @map("change_ref")
  title          String
  description    String    @db.Text
  changeType     String    @default("STANDARD") @map("change_type")
  priority       String    @default("MEDIUM")
  status         String    @default("DRAFT")
  riskLevel      String    @default("LOW") @map("risk_level")
  impact         String    @db.Text
  rollbackPlan   String    @db.Text @map("rollback_plan")
  scheduledStart DateTime? @map("scheduled_start")
  scheduledEnd   DateTime? @map("scheduled_end")
  requesterId    String?   @map("requester_id") @db.Uuid
  requesterName  String?   @map("requester_name")
  approverId     String?   @map("approver_id") @db.Uuid
  approverName   String?   @map("approver_name")
  rejectionNote  String?   @map("rejection_note") @db.Text
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")


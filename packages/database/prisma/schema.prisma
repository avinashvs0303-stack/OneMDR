// ============================================================
//  Clarbit — Prisma Schema
//  PostgreSQL 16 · Multi-tenant (shared DB, tenant_id isolation + RLS)
//  Convention: snake_case columns, PascalCase models, UUID PKs
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")   // Supabase: use direct conn for migrations, pooled for runtime
}

// ── Enums ─────────────────────────────────────────────────────────────────────

enum TenantPlan {
  FREE
  PRO
  ENTERPRISE

  @@map("tenant_plan")
}

enum TenantType {
  STANDARD  // Single-tenant customer — no sub-tenant creation
  MSSP      // Managed Security Service Provider — can create child tenants

  @@map("tenant_type")
}

enum UserRole {
  SUPER_ADMIN // Platform-level: manages all tenants and tenant requests
  OWNER       // Tenant owner (created at approval)
  ADMIN       // Tenant admin
  MEMBER      // Regular member
  GUEST       // Read-only

  @@map("user_role")
}

enum TenantRequestStatus {
  PENDING
  APPROVED
  REJECTED

  @@map("tenant_request_status")
}

enum AuditAction {
  // Auth
  AUTH_LOGIN
  AUTH_LOGOUT
  AUTH_REGISTER
  AUTH_PASSWORD_RESET
  AUTH_MFA_ENABLED
  AUTH_MFA_DISABLED
  AUTH_REFRESH_REVOKED
  // Tenant
  TENANT_CREATED
  TENANT_UPDATED
  TENANT_DELETED
  // User
  USER_INVITED
  USER_ROLE_CHANGED
  USER_REMOVED
  // Tenant requests
  TENANT_REQUEST_SUBMITTED
  TENANT_REQUEST_APPROVED
  TENANT_REQUEST_REJECTED
  // Resource (generic — specific modules extend this)
  RESOURCE_CREATED
  RESOURCE_UPDATED
  RESOURCE_DELETED

  @@map("audit_action")
}

// ── Tenants ───────────────────────────────────────────────────────────────────

model Tenant {
  id        String     @id @default(uuid()) @db.Uuid
  name      String
  slug      String     @unique // URL-safe identifier, e.g. "acme-corp"
  plan      TenantPlan @default(FREE)
  isActive  Boolean    @default(true) @map("is_active")

  // Tenant architecture type — controls whether this tenant can create child tenants
  tenantType     TenantType @default(STANDARD) @map("tenant_type")
  // MSSP hierarchy — null for root tenants, set for MSSP child tenants
  parentTenantId String?    @map("parent_tenant_id") @db.Uuid
  maxSubTenants  Int?       @map("max_sub_tenants")  // null = unlimited (MSSP only)

  // MFA policy — if true, all members must have MFA enabled
  mfaEnforced Boolean @default(false) @map("mfa_enforced")

  // License / entitlements (set at approval time)
  maxUsers         Int      @default(10)  @map("max_users")
  licenseModules   String[] @map("license_modules")  // e.g. ["SIEM","HUNT","COVERAGE"]
  licenseExpiresAt DateTime? @map("license_expires_at")

  // Billing (Step 9)
  stripeCustomerId     String? @unique @map("stripe_customer_id")
  stripeSubscriptionId String? @unique @map("stripe_subscription_id")
  billingEmail         String? @map("billing_email")
  trialEndsAt          DateTime? @map("trial_ends_at")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  users            User[]
  auditLogs        AuditLog[]
  tenantRequest    TenantRequest?
  supportCases     SupportCase[]
  detections       Detection[]
  tenantDetections TenantDetection[]
  detectionStats   DetectionStat[]
  tenantLogSources TenantLogSource[]
  integrations     Integration[]
  integrationLogs  IntegrationLog[]
  huntMissions     HuntMission[]
  huntPlaybooks    HuntPlaybook[]
  huntSchedules    HuntSchedule[]
  socDocuments     SocDocument[]
  socChanges       SocChange[]
  socRequests      SocServiceRequest[]
  socRosterShifts  SocRosterShift[]
  socIncidents     SocIncident[]
  permissionGroups PermissionGroup[]
  groupMemberships GroupMembership[]
  socChannels      SocChannel[]
  parent           Tenant?        @relation("TenantHierarchy", fields: [parentTenantId], references: [id])
  children         Tenant[]       @relation("TenantHierarchy")

  @@index([slug])
  @@map("tenants")
}

// ── Users ─────────────────────────────────────────────────────────────────────

model User {
  id       String   @id @default(uuid()) @db.Uuid
  tenantId String   @map("tenant_id") @db.Uuid
  email    String
  role     UserRole @default(MEMBER)
  isActive Boolean  @default(true) @map("is_active")

  // Profile
  firstName   String  @map("first_name")
  lastName    String  @map("last_name")
  avatarUrl   String? @map("avatar_url")
  timezone    String  @default("UTC")
  locale      String  @default("en")

  // Auth — identity linked to Supabase auth.users via supabase_uid.
  // Password hashing, session management, and token rotation are handled by Supabase Auth.
  // supabase_uid is set by Railway after inviteUserByEmail() returns the Supabase user ID.
  supabaseUid  String?  @unique @map("supabase_uid") @db.Uuid
  emailVerified Boolean @default(false) @map("email_verified")

  // Legacy fields — kept for safe migration; no longer written by application code.
  passwordHash     String?   @map("password_hash")
  emailVerifyToken String?   @map("email_verify_token")
  emailVerifyExpires DateTime? @map("email_verify_expires")

  // MFA
  mfaEnabled      Boolean  @default(false) @map("mfa_enabled")
  mfaSecret       String?  @map("mfa_secret")        // AES-256 encrypted
  mfaBackupCodes  String[] @map("mfa_backup_codes")  // bcrypt hashed

  // OAuth
  googleId String? @unique @map("google_id")

  // Account lockout (brute-force protection)
  loginAttempts   Int       @default(0) @map("login_attempts")
  lockedUntil     DateTime? @map("locked_until")
  lastLoginAt     DateTime? @map("last_login_at")
  lastLoginIp     String?   @map("last_login_ip")

  createdAt DateTime  @default(now()) @map("created_at")
  updatedAt DateTime  @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  tenant              Tenant               @relation(fields: [tenantId], references: [id])
  refreshTokens       RefreshToken[]
  auditLogs           AuditLog[]           @relation("AuditActor")
  passwordResetTokens PasswordResetToken[]
  groupMemberships    GroupMembership[]

  // Email must be unique per tenant (same email can exist in different tenants)
  @@unique([email, tenantId])
  @@index([tenantId])
  @@index([email])
  @@index([googleId])
  @@map("users")
}

// ── Refresh Tokens ────────────────────────────────────────────────────────────

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") // SHA-256 of the raw token
  familyId  String    @map("family_id") @db.Uuid // for reuse-detection; revoke whole family on theft
  deviceInfo String?  @map("device_info")
  ipAddress  String?  @map("ip_address")
  expiresAt DateTime  @map("expires_at")
  revokedAt DateTime? @map("revoked_at")

  createdAt DateTime  @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([familyId])
  @@map("refresh_tokens")
}

// ── Audit Log — immutable, append-only ────────────────────────────────────────

model AuditLog {
  id         String      @id @default(uuid()) @db.Uuid
  tenantId   String      @map("tenant_id") @db.Uuid
  actorId    String?     @map("actor_id") @db.Uuid  // NULL = system event
  action     AuditAction
  resource   String?     // e.g. "board", "item", "user"
  resourceId String?     @map("resource_id") @db.Uuid
  metadata   Json?       // extra context (diff, old/new values)
  ipAddress  String?     @map("ip_address")
  userAgent  String?     @map("user_agent")

  createdAt  DateTime    @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  actor  User?  @relation("AuditActor", fields: [actorId], references: [id])

  // No updated_at / deleted_at — audit logs are immutable
  @@index([tenantId, createdAt(sort: Desc)])
  @@index([tenantId, actorId])
  @@index([tenantId, action])
  @@map("audit_logs")
}

// ── Password Reset Tokens ─────────────────────────────────────────────────────

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") // SHA-256 of the raw token
  expiresAt DateTime  @map("expires_at")
  usedAt    DateTime? @map("used_at")  // single-use enforcement

  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

// ── Tenant Requests — approval queue ─────────────────────────────────────────

model TenantRequest {
  id   String @id @default(uuid()) @db.Uuid

  // Applicant details
  companyName   String  @map("company_name")
  companySize   String? @map("company_size")  // e.g. "1-10", "11-50", "51-200", "201+"
  industry      String?
  website       String?
  contactName   String  @map("contact_name")
  contactEmail  String  @unique @map("contact_email")
  contactPhone  String? @map("contact_phone")
  useCase       String? @map("use_case")  // free-text: why they want the product

  // Workflow status
  status          TenantRequestStatus @default(PENDING)
  reviewedById    String?             @map("reviewed_by_id") @db.Uuid
  reviewedAt      DateTime?           @map("reviewed_at")
  rejectionReason String?             @map("rejection_reason")
  adminNotes      String?             @map("admin_notes")

  // License configuration — set by super admin during approval
  planType         TenantPlan @default(FREE)     @map("plan_type")
  tenantType       TenantType @default(STANDARD) @map("tenant_type")
  maxUsers         Int        @default(10)       @map("max_users")
  maxSubTenants    Int?                          @map("max_sub_tenants")
  licenseModules   String[]                      @map("license_modules")  // ["SIEM","HUNT","COVERAGE",...]
  licenseExpiresAt DateTime?                     @map("license_expires_at")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  // Once approved a Tenant + OWNER User are created and linked here
  tenantId String? @unique @map("tenant_id") @db.Uuid
  tenant   Tenant? @relation(fields: [tenantId], references: [id])

  @@index([status, createdAt(sort: Desc)])
  @@index([contactEmail])
  @@map("tenant_requests")
}

// ── Support Cases ─────────────────────────────────────────────────────────────

// ── Detection Library ─────────────────────────────────────────────────────────

enum DetectionSeverity {
  CRITICAL
  HIGH
  MEDIUM
  LOW
  INFO

  @@map("detection_severity")
}

enum DetectionRuleType {
  ANOMALY
  INVESTIGATE
  HIGH_FIDELITY
  CORRELATION
  THREAT_INTEL

  @@map("detection_rule_type")
}

enum DetectionLifecycle {
  EXPERIMENTAL
  FUNCTIONAL
  STABLE
  RETIRED

  @@map("detection_lifecycle")
}

enum DetectionWorkflowStatus {
  PENDING
  IN_PROGRESS
  REVIEW
  APPROVED
  ENABLED
  DISABLED

  @@map("detection_workflow_status")
}

enum DetectionPlatform {
  SPLUNK
  SENTINEL
  CHRONICLE
  ELASTIC
  QRADAR
  DEFENDER
  SIGMA
  CUSTOM

  @@map("detection_platform")
}

enum QueryLanguage {
  SPL      // Splunk Processing Language
  KQL      // Kusto Query Language (Sentinel)
  YARA_L   // Chronicle YARA-L 2.0
  EQL      // Event Query Language (Elastic)
  AQL      // Ariel Query Language (QRadar)
  SIGMA    // SIGMA generic format
  CUSTOM

  @@map("query_language")
}

model Detection {
  id          String            @id @default(uuid()) @db.Uuid
  ruleId      String            @unique @map("rule_id")  // DET-0001 format
  name        String
  description String
  severity    DetectionSeverity
  platform    DetectionPlatform

  // MITRE ATT&CK
  mitreAttackId   String? @map("mitre_attack_id")   // e.g. T1059.001
  mitreTactic     String? @map("mitre_tactic")       // e.g. Execution
  mitreTechnique  String? @map("mitre_technique")    // e.g. Command and Scripting Interpreter: PowerShell

  // Compliance
  nistControls String[] @default([]) @map("nist_controls")   // ["SI-3","SI-4"]
  dataSources  String[] @default([]) @map("data_sources")    // ["Windows Event Logs (4688)"]

  // Query
  query         String
  queryLanguage QueryLanguage @map("query_language")

  // Metadata
  tags                 String[]  @default([])
  expectedAlertsPerDay Decimal?  @map("expected_alerts_per_day") @db.Decimal(8, 2)
  expectedFpRate       Decimal?  @map("expected_fp_rate")        @db.Decimal(5, 2)  // 0-100 %
  expectedMttdHours    Decimal?  @map("expected_mttd_hours")     @db.Decimal(8, 2)

  // Log source / device type classification (used for proposal matching)
  logSources  String[] @default([]) @map("log_sources")   // e.g. ["Windows Security","Authentication"]
  deviceTypes String[] @default([]) @map("device_types")  // e.g. ["Windows AD","Firewall"]

  // Ownership — null tenantId = global seeded rule; set = custom rule for that tenant
  isGlobal  Boolean @default(false) @map("is_global")
  tenantId  String? @map("tenant_id") @db.Uuid

  // Rule classification metadata
  ruleType       DetectionRuleType?       @map("rule_type")
  lifecycleStage DetectionLifecycle       @default(EXPERIMENTAL) @map("lifecycle_stage")
  workflowStatus DetectionWorkflowStatus  @default(PENDING)      @map("workflow_status")
  ownerName      String?                  @map("owner_name")
  ownerId        String?                  @map("owner_id") @db.Uuid

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  tenant           Tenant?           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  tenantDetections TenantDetection[]
  stats            DetectionStat[]
  siemDeployments  SiemDeployment[]

  @@index([platform])
  @@index([severity])
  @@index([mitreAttackId])
  @@index([tenantId])
  @@index([isGlobal])
  @@map("detections")
}

model TenantLogSource {
  id         String   @id @default(uuid()) @db.Uuid
  tenantId   String   @map("tenant_id") @db.Uuid
  logSource  String   @map("log_source")   // e.g. "Windows Security", "Firewall Logs"
  deviceType String?  @map("device_type")  // optional free-text, e.g. "Palo Alto PA-5000"
  vendor     String?                       // e.g. "Palo Alto", "Microsoft"
  createdAt  DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, logSource])
  @@index([tenantId])
  @@map("tenant_log_sources")
}

model TenantDetection {
  id          String  @id @default(uuid()) @db.Uuid
  tenantId    String  @map("tenant_id")    @db.Uuid
  detectionId String  @map("detection_id") @db.Uuid
  isEnabled   Boolean @default(true)       @map("is_enabled")
  enabledAt   DateTime @default(now())     @map("enabled_at")
  enabledById String?  @map("enabled_by_id") @db.Uuid

  tenant    Tenant    @relation(fields: [tenantId],    references: [id], onDelete: Cascade)
  detection Detection @relation(fields: [detectionId], references: [id], onDelete: Cascade)

  @@unique([tenantId, detectionId])
  @@index([tenantId, isEnabled])
  @@map("tenant_detections")
}

model DetectionStat {
  id          String   @id @default(uuid()) @db.Uuid
  tenantId    String   @map("tenant_id")    @db.Uuid
  detectionId String   @map("detection_id") @db.Uuid
  date        DateTime @map("date")         @db.Date

  triggerCount   Int     @default(0) @map("trigger_count")
  truePositives  Int     @default(0) @map("true_positives")
  falsePositives Int     @default(0) @map("false_positives")
  mttdMinutes    Decimal? @map("mttd_minutes") @db.Decimal(10, 2)

  tenant    Tenant    @relation(fields: [tenantId],    references: [id], onDelete: Cascade)
  detection Detection @relation(fields: [detectionId], references: [id], onDelete: Cascade)

  @@unique([tenantId, detectionId, date])
  @@index([tenantId, detectionId])
  @@index([tenantId, date])
  @@map("detection_stats")
}

enum SupportCaseStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED

  @@map("support_case_status")
}

enum SupportCasePriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL

  @@map("support_case_priority")
}

model SupportCase {
  id       String @id @default(uuid()) @db.Uuid
  tenantId String @map("tenant_id") @db.Uuid

  title       String
  description String

  priority SupportCasePriority @default(MEDIUM)
  status   SupportCaseStatus   @default(OPEN)

  submittedByEmail String  @map("submitted_by_email")
  submittedByName  String  @map("submitted_by_name")
  assignedToEmail  String? @map("assigned_to_email")

  internalNotes   String? @map("internal_notes")
  resolutionNotes String? @map("resolution_notes")

  createdAt  DateTime  @default(now()) @map("created_at")
  updatedAt  DateTime  @updatedAt      @map("updated_at")
  resolvedAt DateTime? @map("resolved_at")

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([status])
  @@index([priority])
  @@map("support_cases")
}

// ── SIEM Integrations ─────────────────────────────────────────────────────────

enum IntegrationStatus {
  UNCONFIGURED
  CONNECTED
  ERROR
  DEGRADED

  @@map("integration_status")
}

model Integration {
  id       String            @id @default(uuid()) @db.Uuid
  tenantId String            @map("tenant_id") @db.Uuid
  platform DetectionPlatform
  name     String

  // Connection — host URL for REST-based SIEMs
  host     String  @default("")
  // Credentials stored as an encrypted JSON blob at the application layer
  config   Json    @default("{}")

  status       IntegrationStatus @default(UNCONFIGURED)
  lastTestedAt DateTime?         @map("last_tested_at")
  errorMessage String?           @map("error_message")
  isEnabled    Boolean           @default(true) @map("is_enabled")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  tenant        Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  deployments   SiemDeployment[]
  logs          IntegrationLog[]
  huntSchedules HuntSchedule[]

  @@unique([tenantId, platform, name])
  @@index([tenantId])
  @@map("integrations")
}

model SiemDeployment {
  id            String @id @default(uuid()) @db.Uuid
  integrationId String @map("integration_id") @db.Uuid
  detectionId   String @map("detection_id") @db.Uuid
  remoteId      String? @map("remote_id")    // ID assigned by the target SIEM
  status        String  @default("deployed") // deployed | error | removed
  errorMessage  String? @map("error_message")
  deployedAt    DateTime @default(now()) @map("deployed_at")
  updatedAt     DateTime @updatedAt      @map("updated_at")

  integration Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  detection   Detection   @relation(fields: [detectionId],   references: [id], onDelete: Cascade)

  @@unique([integrationId, detectionId])
  @@index([integrationId])
  @@index([detectionId])
  @@map("siem_deployments")
}

// ── Integration Logs ─────────────────────────────────────────────────────────

model IntegrationLog {
  id            String   @id @default(uuid()) @db.Uuid
  tenantId      String   @map("tenant_id") @db.Uuid
  integrationId String   @map("integration_id") @db.Uuid
  event         String   // TEST_CONNECTION | DEPLOY | UNDEPLOY | CREATE | UPDATE | DELETE
  level         String   @default("INFO") // INFO | WARN | ERROR
  message       String
  meta          Json?
  durationMs    Int?     @map("duration_ms")
  createdAt     DateTime @default(now()) @map("created_at")

  tenant      Tenant      @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  integration Integration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@index([tenantId, createdAt(sort: Desc)])
  @@index([integrationId, createdAt(sort: Desc)])
  @@map("integration_logs")
}

// ── Threat Hunting as a Service (THaaS) ──────────────────────────────────────

enum HuntStatus {
  PLANNED
  ACTIVE
  COMPLETE
  ARCHIVED

  @@map("hunt_status")
}

enum HuntPriority {
  CRITICAL
  HIGH
  MEDIUM
  LOW

  @@map("hunt_priority")
}

enum HuntEvidenceType {
  FINDING
  FALSE_POSITIVE
  ARTIFACT
  NOTE

  @@map("hunt_evidence_type")
}

enum HuntIOCType {
  IP
  DOMAIN
  HASH_MD5
  HASH_SHA1
  HASH_SHA256
  URL
  EMAIL
  REGISTRY_KEY
  FILE_PATH
  OTHER

  @@map("hunt_ioc_type")
}

model HuntMission {
  id         String       @id @default(uuid()) @db.Uuid
  tenantId   String       @map("tenant_id") @db.Uuid
  missionRef String       @map("mission_ref") // e.g. HNT-0007, auto-generated
  title      String
  hypothesis String       @db.Text
  status     HuntStatus   @default(PLANNED)
  priority   HuntPriority @default(MEDIUM)

  // MITRE ATT&CK mapping
  tacticId   String?  @map("tactic_id")
  tactic     String?
  techniques String[] @default([])

  // Assignment
  analystId   String?   @map("analyst_id") @db.Uuid
  analystName String?   @map("analyst_name")
  startDate   DateTime? @map("start_date")
  endDate     DateTime? @map("end_date")
  notes       String?   @db.Text

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  tenant   Tenant        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  evidence HuntEvidence[]
  iocs     HuntIOC[]

  @@unique([tenantId, missionRef])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, priority])
  @@map("hunt_missions")
}

model HuntEvidence {
  id        String           @id @default(uuid()) @db.Uuid
  missionId String           @map("mission_id") @db.Uuid
  tenantId  String           @map("tenant_id") @db.Uuid
  type      HuntEvidenceType @default(FINDING)
  title     String
  body      String           @db.Text
  severity  String           @default("MEDIUM") // HIGH | MEDIUM | LOW | INFO
  isFalsePositive Boolean    @default(false) @map("is_false_positive")
  rawData   Json?            @map("raw_data")
  analystId   String? @map("analyst_id") @db.Uuid
  analystName String? @map("analyst_name")

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  mission HuntMission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@index([missionId])
  @@index([tenantId])
  @@map("hunt_evidence")
}

model HuntIOC {
  id         String      @id @default(uuid()) @db.Uuid
  missionId  String      @map("mission_id") @db.Uuid
  tenantId   String      @map("tenant_id") @db.Uuid
  type       HuntIOCType
  value      String
  confidence String      @default("MEDIUM") // HIGH | MEDIUM | LOW
  notes      String?

  createdAt DateTime @default(now()) @map("created_at")

  mission HuntMission @relation(fields: [missionId], references: [id], onDelete: Cascade)

  @@index([missionId])
  @@index([tenantId, type])
  @@map("hunt_iocs")
}

// ── THaaS Playbooks ───────────────────────────────────────────────────────────

model HuntPlaybook {
  id              String   @id @default(uuid()) @db.Uuid
  tenantId        String?  @map("tenant_id") @db.Uuid  // null = global (platform-provided)
  playbookRef     String   @map("playbook_ref")         // PBK-0001
  title           String
  description     String   @db.Text
  category        String                                 // Ransomware | APT | Lateral Movement …
  mitreTacticId   String?  @map("mitre_tactic_id")
  mitreTactic     String?  @map("mitre_tactic")
  mitreTechniques String[] @default([]) @map("mitre_techniques")
  severity        String   @default("HIGH")
  estimatedHours  Int      @default(4) @map("estimated_hours")
  tags            String[] @default([])
  // JSON array: Array<{name:string; description:string; query:string; earliest:string; latest:string}>
  queries         Json     @default("[]")
  isGlobal        Boolean  @default(false) @map("is_global")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  tenant    Tenant?        @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  schedules HuntSchedule[]

  @@unique([tenantId, playbookRef])
  @@index([tenantId])
  @@index([isGlobal])
  @@map("th_playbooks")
}

// ── THaaS Schedules ───────────────────────────────────────────────────────────

model HuntSchedule {
  id                String    @id @default(uuid()) @db.Uuid
  tenantId          String    @map("tenant_id") @db.Uuid
  playbookId        String    @map("playbook_id") @db.Uuid
  integrationId     String    @map("integration_id") @db.Uuid
  scheduleRef       String    @map("schedule_ref")   // SCH-0001
  name              String
  cronExpression    String    @map("cron_expression") // standard 5-field cron
  isEnabled         Boolean   @default(true) @map("is_enabled")
  nextRunAt         DateTime? @map("next_run_at")
  lastRunAt         DateTime? @map("last_run_at")
  lastRunStatus     String?   @map("last_run_status") // RUNNING | SUCCESS | FAILED | NO_RESULTS
  autoCreateMission Boolean   @default(true) @map("auto_create_mission")
  minResultCount    Int       @default(1) @map("min_result_count")
  createdAt         DateTime  @default(now()) @map("created_at")
  updatedAt         DateTime  @updatedAt @map("updated_at")

  tenant      Tenant       @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  playbook    HuntPlaybook @relation(fields: [playbookId], references: [id])
  integration Integration  @relation(fields: [integrationId], references: [id])
  runs        HuntScheduleRun[]

  @@unique([tenantId, scheduleRef])
  @@index([tenantId])
  @@index([isEnabled, nextRunAt])
  @@map("th_schedules")
}

model HuntScheduleRun {
  id           String    @id @default(uuid()) @db.Uuid
  scheduleId   String    @map("schedule_id") @db.Uuid
  tenantId     String    @map("tenant_id") @db.Uuid
  startedAt    DateTime  @default(now()) @map("started_at")
  completedAt  DateTime? @map("completed_at")
  status       String    // RUNNING | SUCCESS | FAILED | NO_RESULTS
  resultCount  Int       @default(0) @map("result_count")
  missionId    String?   @map("mission_id") @db.Uuid  // auto-created mission, if any
  errorMessage String?   @map("error_message")
  querySummary Json?     @map("query_summary")

  schedule HuntSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([scheduleId])
  @@index([tenantId])
  @@map("th_schedule_runs")
}

// ── SOC Documents ─────────────────────────────────────────────────────────────

model SocDocument {
  id          String   @id @default(uuid()) @db.Uuid

# ════════════════════════════════════════════════════════════════════════════
#  Clarbit — Environment Configuration
#  Copy to .env and fill in your values. NEVER commit .env.
#  Generate secrets with:  openssl rand -hex 32
# ════════════════════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
APP_NAME=Clarbit
API_PREFIX=api/v1

# ── Database (PostgreSQL 16) ─────────────────────────────────────────────────
POSTGRES_DB=clarbit
POSTGRES_USER=clarbit
POSTGRES_PASSWORD=clarbit_secret
POSTGRES_PORT=5432
DATABASE_URL=postgresql://clarbit:clarbit_secret@localhost:5432/clarbit?schema=public

# ── Redis ────────────────────────────────────────────────────────────────────
REDIS_PASSWORD=redis_secret
REDIS_PORT=6379
REDIS_URL=redis://:redis_secret@localhost:6379

# ── Auth — generate NEW secrets before deploying! ────────────────────────────
# openssl rand -hex 32  →  64 hex chars = 32 bytes = 256 bits
JWT_SECRET=CHANGE_ME_use_openssl_rand_hex_32_for_jwt_access_secret
JWT_ACCESS_EXPIRES_IN=15m

REFRESH_TOKEN_SECRET=CHANGE_ME_use_openssl_rand_hex_32_for_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

# ── Field Encryption (must be exactly 32 bytes / 64 hex chars) ───────────────
# Used for: MFA secrets, backup codes, sensitive PII fields
# openssl rand -hex 32
ENCRYPTION_KEY=CHANGE_ME_32_byte_hex_key_for_aes256_field_level_encryption

# ── OAuth — Google ───────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:3001/api/v1/auth/google/callback

# ── Email (SMTP) ─────────────────────────────────────────────────────────────
# For local dev: docker compose --profile mail up  →  http://localhost:8025
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_USER=
SMTP_PASS=
SMTP_FROM=no-reply@clarbit.com

# ── Frontend ─────────────────────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3001/api/v1
NEXT_PUBLIC_WS_URL=ws://localhost:3001

# ── Supabase ─────────────────────────────────────────────────────────────────
# Project → Settings → API in the Supabase dashboard
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here
# Service role key — ONLY for server-side code, NEVER expose to browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ── Dev bypass ───────────────────────────────────────────────────────────────
# Set to "true" locally to skip auth and log in as a demo user automatically.
# NEVER set this in production — middleware enforces it is off when NODE_ENV=production.
NEXT_PUBLIC_DEV_BYPASS_AUTH=true

# ── Stripe (Step 9 — billing scaffold) ──────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_CHANGE_ME
STRIPE_WEBHOOK_SECRET=whsec_CHANGE_ME
STRIPE_PRICE_PRO_MONTHLY=price_CHANGE_ME
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_CHANGE_ME
